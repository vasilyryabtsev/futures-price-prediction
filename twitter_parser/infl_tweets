{"username": "SallieKrawcheck", "name": "Sallie Krawcheck", "text": "Awards season is upon us, and not just in Hollywood. For some reason, last week was the unofficial \u201clet\u2019s recognize women\u201d week. And that means lists galore. Fortune\u2019s \u201cMost Powerful Women.\u201d Inc. Magazine\u2019s \u201cFemale Founders 100.\u201d Entrepreneur Magazine\u2019s \u201c100 Women of Influence.\u201d", "lang": "en", "in_reply_to": "1580241647408848896", "is_quote_status": false, "retweeted_tweet": null, "possibly_sensitive": null, "favorited": false, "date": "Wed Oct 12 16:59:03 +0000 2022", "quote_count": 0, "reply_count": 1, "favorite_count": 1, "view_count": null, "view_count_state": "Enabled", "retweet_count": 0, "place": null, "is_translatable": false, "edits_remaining": "5", "has_card": false, "thumbnail_title": null, "urls": [], "hashtags": []}
